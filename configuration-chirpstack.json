/*------------- CONTAINERS -------------*/

const containerList = [
    /*Containers will be created in order, starting from containerList[0] until containerList[n]*/
    { image: "alpine:20260127", config: alpineConfigInit, name: "AlpineConfigInit" },
    { image: "alpine:20260127", config: alpinePostgresConfig, name: "Alipinepostgres" },
    { image: "codercom/code-server:4.112.0-39", config: configUIConfig, name: "vsCodeInBrowser" },
    { image: "eclipse-mosquitto:2.0.21", config: mosquittoConfig, name: "mosquitto" },
    { image: "postgres:15.12-alpine", config: postgresConfig, name: "postgres" },
    { image: "redis:7-alpine", config: redisConfig, name: "redis" },
    { image: "chirpstack/chirpstack:4.11", config: chirpstackConfig, name: "chirpstack" },
    { image: "chirpstack/chirpstack-gateway-bridge:4.0.11", config: gatewaybridgeConfig, name: "gateway-bridge" },
    { image: "montagny/node-red:1.2", config: noderedConfig, name: "nodered" }
];

msg.containerList = containerList;
msg.globalconfig = globalconfig;

