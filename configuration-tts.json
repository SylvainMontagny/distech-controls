/* this is a configuration file meant to be use with the distech-service-setup node-red flow (https://github.com/SylvainMontagny/distech-controls), 
to use it, renseign the configuration parameters in this file (global and specific for each container), then simply paste the content of this file in the TO CONFIGURE node */

/*--------- GLOBAL CONFIGURATION ---------*/
const globalconfig =
{
    /*flowmode = 0 : delete containers and images*/
    /*flowmode = 1 : create and start listed containers*/
    flowmode: 1,
    ip: "", /*target's ip address*/
    httpAuth: "", /*http auth header*/
    login: "", /*login*/
    password: "", /*password*/
    network: "" /*network name*/
}

/*--------- CONTAINERS CONFIGURATION ---------*/
const redisConfig = 
{
    "Cmd": ["redis-server", "--save", "300", "1", "--save", "60", "100", "--appendonly", "yes"],
    "HostConfig": {
        "Binds": ["redis-volume:/data"],
        "RestartPolicy": { "Name": "unless-stopped" }
    }
}

const postgresConfig =
{
    "Env": [
        /*change if needed, but you must then update the TTS configuration accordingly*/
        "POSTGRES_PASSWORD=root",     
        "POSTGRES_USER=root",    
        "POSTGRES_DB=ttn_lorawan" 
    ],
    "HostConfig": {
        "Binds": ["postgres-volume:/var/lib/postgresql/data"],
        "RestartPolicy": { "Name": "unless-stopped" }
    }
}

const TTS_DOMAIN = "TTS_DOMAIN=" + globalconfig.ip;
const thethingsstackConfig =
{
    "Env": [
        TTS_DOMAIN,
        "TTS_PORT=50085",
        "TTN_LW_BLOB_LOCAL_DIRECTORY=/srv/ttn-lorawan/public/blob",
        "TTN_LW_REDIS_ADDRESS=redis:6379",
        "TTN_LW_IS_DATABASE_URI=postgres://root:root@postgres:5432/ttn_lorawan?sslmode=disable",
        "CLI_AUTO_LOGIN=true"
    ],
    "HostConfig": {
        "Binds": [
            "stack-blob:/srv/ttn-lorawan/public/blob",
            "stack-data:/srv/data"
        ],
        "PortBindings": {
            "8885/tcp": [{ "HostPort": "50085" }],
            "8884/tcp": [{ "HostPort": "50084" }],
            "8887/tcp": [{ "HostPort": "50087" }],
            "1700/udp": [{ "HostPort": "50017" }]
        },
        "RestartPolicy": { "Name": "unless-stopped" },
        "Links": ["postgres:postgres-tts-link", "redis:redis-tts-link"]
    }
}

const nodereConfig =
{
    "Image": "montagny/node-red:latest",
    "HostConfig": {
        "Binds": ["nodereddata-volume:/data"],
        "PortBindings": { "1880/tcp": [{ "HostPort": "50080" }] },
        "RestartPolicy": { "Name": "unless-stopped" },
        "Links": ["thethingsstack:nodered-tts-link"]
    }
}

/*------------- CONTAINERS -------------*/

const containerList = [
    /*Containers will be created in order, starting from containerList[0] until containerList[n]*/
    { image: "redis:7.4.2-alpine3.21", config: redisConfig, name: "redis" },
    { image: "postgres:16.8-alpine3.20", config: postgresConfig, name: "postgres" },
    { image: "xoseperez/the-things-stack:v1.3.0", config: thethingsstackConfig, name: "thethingsstack" },
    { image: "montagny/node-red:1.2", config: nodereConfig, name: "nodered" }
];

msg.containerList = containerList;
msg.globalconfig = globalconfig;

return msg;