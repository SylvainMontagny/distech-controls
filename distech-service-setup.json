        "type": "function",
        "z": "ca05722bab3f9dfc",
        "g": "ad953a59137e678a",
        "name": "Stop container",
        "func": "node.warn(msg.globalconfig.ip);\n\nlet containers = Object.values(msg.payload);\nlet index = 0;\n\ncontainers.keys();\n\nfor (let i = 0; i < containers.length; i++) {\n\n  let container = containers[i];\n\n  let tosend = {\n    globalconfig: msg.globalconfig,\n    msgNumber: index,\n    containername: container.key,\n    method: \"POST\",\n    url: \"https://\" + msg.globalconfig.ip + \"/api/rest/v2/services/containerization/containers/stop\",\n\n    headers: {\n      Authorization: msg.globalconfig.httpAuth,\n      \"Content-Type\": \"application/json\"\n    },\n\n    payload: {\n      \"container-name\": container.key\n    }\n  };\n\n  node.send(tosend);\n  node.warn(`stopping container ${container.key} (${container.state})`);\n\n  index++;\n}\nreturn null;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
