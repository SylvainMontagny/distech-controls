/* this is a configuration file meant to be use with the distech-service-setup node-red flow (https://github.com/SylvainMontagny/distech-controls), 
to use it, renseign the configuration parameters in this file (global and specific for each container), then simply paste the content of this file in the TO CONFIGURE CHIRPSTACK node */

/*--------- GLOBAL CONFIGURATION ---------*/

const globalconfig =
{
    /*flowmode = 0 : delete containers and images*/
    /*flowmode = 1 : create and start listed containers*/
    flowmode: 1,
    ip: "", /*target's ip address*/
    httpAuth: "", /*http auth header*/
    login: "", /*login*/
    password: "", /*password*/
    network: "" /*network name*/
}

/*--------- CONTAINERS CONFIGS ---------*/

const mosquittoConfig = {
    "HostConfig": {
        "RestartPolicy": { "Name": "unless-stopped" },
        "Binds": [
            "mosquitto-volume:/mosquitto/config",
            "mosquitto-data-volume:/mosquitto/data",
            "mosquitto-log-volume:/mosquitto/log"
        ]
    }
};


const postgresConfig = {
    "Env": ["POSTGRES_PASSWORD="], /*setup your password, syntax: PASSWORD=your_password*/
    "HostConfig": {
        "Binds": [
            "postgres-volume:/docker-entrypoint-initdb.d",
            "postgresdata-volume:/var/lib/postgresql/data"
        ],
        "RestartPolicy": { "Name": "unless-stopped" }
    }
};


const redisConfig = {
    "Cmd": ["redis-server", "--save", "300", "1", "--save", "60", "100", "--appendonly", "no"],
    "HostConfig": {
        "Binds": [
            "redis-volume:/redis",
            "redisdata-volume:/data"
        ],
        "RestartPolicy": { "Name": "unless-stopped" }
    }
};


const chirpstackConfig = {
    "User": "1000:1000",
    "ExposedPorts": { "8080/tcp": {} },
    "Env": [
        "MQTT_BROKER_HOST=mosquitto",
        "REDIS_HOST=redis",
        "POSTGRESQL_HOST=postgres"
        ],
    "HostConfig": {
        "Binds": [
            "chirpstack-volume:/etc/chirpstack",
            "lorawandevices-volume:/opt/lorawan-devices"
        ],
        "PortBindings": { "8080/tcp": [{ "HostPort": "50101" }] },
        "RestartPolicy": { "Name": "unless-stopped" },
        "Links": ["postgres:postgres-chirpstack-link", "mosquitto:mosquitto-chirpstack-link", "redis:redis-chirpstack-link"]
    },
   "Cmd": ["-c", "/etc/chirpstack"]
};


const gatewaybridgeConfig = {
   "ExposedPorts": { "1700/udp": {} },
    "Env": [
     "INTEGRATION__MQTT__EVENT_TOPIC_TEMPLATE=eu868/gateway/{{ .GatewayID }}/event/{{ .EventType }}",
     "INTEGRATION__MQTT__STATE_TOPIC_TEMPLATE=eu868/gateway/{{ .GatewayID }}/state/{{ .StateType }}",
     "INTEGRATION__MQTT__COMMAND_TOPIC_TEMPLATE=eu868/gateway/{{ .GatewayID }}/command/#"
    ],
    "HostConfig": {
        "Binds": [ "gateway-bridge-volume:/etc/chirpstack-gateway-bridge" ],
        "PortBindings": { "1700/udp": [{ "HostPort": "50103" }] },
        "RestartPolicy": { "Name": "unless-stopped" },
        "Links": ["mosquitto:mosquitto-gateway-link"]
   }
};



const noderedConfig = {
    "HostConfig": {
        "Binds": ["nodereddata-volume:/data"],
        "PortBindings": { "1880/tcp": [{ "HostPort": "50102" }] },
        "RestartPolicy": { "Name": "unless-stopped" }
    }
};


const configUIConfig = {
    "User": "0:0",  
    "Env": [
        "PASSWORD= "  /*setup your password, syntax: PASSWORD=your_password*/
    ],
    "HostConfig": {
        "Binds": [
            "mosquitto-volume:/workspace/mosquitto",
            "chirpstack-volume:/workspace/chirpstack",
            "gateway-bridge-volume:/workspace/gatewaybridge"
        ],
        "PortBindings": { "8080/tcp": [{ "HostPort": "50200" }] },
        "RestartPolicy": { "Name": "unless-stopped" }
    },
    "WorkingDir": "/workspace"
};
const alpinePostgresConfig =
{
    "Cmd": [
        "sh", "-c",
        "cat > /scripts/001-init-chirpstack.sh << 'EOF1'\n#!/bin/bash\nset -e\npsql -v ON_ERROR_STOP=1 --username \"$POSTGRES_USER\" <<-EOSQL\n    create role chirpstack with login password 'chirpstack';\n    create database chirpstack with owner chirpstack;\nEOSQL\nEOF1\n\ncat > /scripts/002-chirpstack_extensions.sh << 'EOF2'\n#!/bin/bash\nset -e\n\npsql -v ON_ERROR_STOP=1 --username \"$POSTGRES_USER\" --dbname=\"chirpstack\" <<-EOSQL\n    create extension pg_trgm;\n    create extension hstore;\nEOSQL\nEOF2\n\nchmod +x /scripts/*.sh\nchown 999:999 /scripts/*.sh"
    ],
    "HostConfig": {
        "Binds": ["postgres-volume:/scripts"],
        "AutoRemove": false
    }
}
