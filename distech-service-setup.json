        "type": "function",
        "z": "ca05722bab3f9dfc",
        "g": "9ff47e4845576194",
        "name": "queue manager",
        "func": "let queue = flow.get('queue');\nlet queueToken = flow.get('queueToken');\nlet queueCount = flow.get('queueCount');\n\n\nif (msg.queueToken) \n{\n    flow.set('queueToken', 1); \n}\nelse\n{\n    queue.push(msg);\n    flow.set('queue', queue);\n}\n\nif (flow.get('queueToken'))\n{\n    let index = queue.findIndex(m => m.msgNumber === queueCount);\n    if (index !== -1) \n    {\n        let outMsg = queue.splice(index, 1)[0];\n        flow.set('queue', queue);\n        flow.set('queueCount', queueCount + 1);\n        flow.set('queueToken',0);\n        return outMsg;\n    }\n    else \n    {\n        return null;\n    }\n}\nelse\n{\n    return null;\n}\n\n",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "flow.set('queueToken', 1);\nflow.set('queueCount', 0);\nflow.set('queue',[]);",
